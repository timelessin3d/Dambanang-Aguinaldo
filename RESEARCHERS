<style>

/* =========================
   ROOT COLORS
========================= */

:root{
  --jaguar:#06030A;
  --white:#ffffff;
  --blaze-orange:#f96800;
  --yellow-orange:#ffb200;
  --dark-purple:#3a1f63;
}

/* =========================
   GLOBAL
========================= */

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background:#000;
  color:#fff;
  font-family:'Montserrat',sans-serif;
  overflow-x:hidden;
}

a{
  text-decoration:none;
  color:#fff;
}

img{
  width:100%;
  display:block;
}

/* =========================
   HEADER CSS
========================= */

header{
  width:100%;
  height:75px;

  background:
  radial-gradient(circle at 50% 50%,
  var(--dark-purple),
  #000000);

  display:flex;
  justify-content:space-between;
  align-items:center;

  padding:0 40px;

  position:fixed;
  top:0;
  left:0;
  z-index:1000;
}

/* NAV */

.nav-left,
.nav-right{
  display:flex;
  align-items:center;
  gap:20px;
   justify-content: center;
}

.nav-item{
  display:flex;
  align-items:center;
  gap:8px;
}

/* CENTER LOGO */

.logo-center{
  position:absolute;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  align-items:center;
}

.logo-center img{
  width:200px;
  height:auto;
}

/* LINKS */

.nav-link{
  font-size:15px;
  font-weight:600;
  letter-spacing:1px;
  transition:0.3s ease;
}

.nav-link:hover{
  color:var(--yellow-orange);
  transform:scale(1.08);
}

/* ACTIVE BUTTON */

.active-btn{
  background:transparent;
  height:75px;
  min-width:88px;

  padding:0 24px;

  display:flex;
  justify-content:center;
  align-items:center;
}

.active-btn .nav-link{
  color:var(--yellow-orange);
}

/* DROPDOWN DOT */

.dropdown-dot{
  width:20px;
  height:20px;

  background:var(--blaze-orange);
  border-radius:50%;

  position:relative;

  box-shadow:-3px 3px 8px rgba(255,178,0,0.5);

  transition:0.35s ease;
}

.dropdown-dot::after{
  content:"";
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%, -70%);
  border-left:5px solid transparent;
  border-right:5px solid transparent;
  border-bottom:8px solid white;
}

/* ROTATE */

.about-dropdown-wrapper[open] .dropdown-dot,
.virtual-dropdown-wrapper[open] .dropdown-dot{
  transform:rotate(180deg);
}

/* ABOUT */

.about-dropdown-wrapper{
  position:relative;
}

.about-dropdown-wrapper summary::-webkit-details-marker{
  display:none;
}

.about-dropdown-summary{
  display:flex;
  align-items:center;
  gap:12px;
  cursor:pointer;
  list-style:none;
}

/* VIRTUAL */

.virtual-dropdown-wrapper{
  position:relative;
}

.virtual-dropdown-wrapper summary::-webkit-details-marker{
  display:none;
}

.virtual-dropdown-summary{
  display:flex;
  align-items:center;
  gap:12px;
  cursor:pointer;
  list-style:none;
}

/* DROPDOWN MENU */

.dropdown-menu{
  position:fixed;

  top:75px;
  left:0;

  width:100%;

  background:var(--yellow-orange);

  padding:40px 138px;

  box-shadow:0 10px 30px rgba(0,0,0,0.25);

  z-index:999;

  opacity:0;
  visibility:hidden;

  transform:translateY(-10px);

  transition:0.35s ease;
}

.about-dropdown-wrapper[open] .dropdown-menu,
.virtual-dropdown-wrapper[open] .dropdown-menu{
  opacity:1;
  visibility:visible;
  transform:translateY(0);
}

/* GRID */

.dropdown-grid{
  width:100%;
}

.dropdown-column{
  display:flex;
  justify-content:space-between;
  width:100%;
}

/* DROPDOWN LINKS */

.dropdown-link{
  position:relative;
  padding-bottom:10px;
  width:280px;
}

.dropdown-link span{
  font-size:15px;
  font-weight:500;
  color:white;
  transition:0.35s ease;
}

.dropdown-link::after{
  content:"";
  width:100%;
  height:2px;
  background:white;

  position:absolute;
  left:0;
  bottom:0;

  transform:scaleX(1);
  transform-origin:left;

  transition:
  transform 0.45s ease-in-out,
  background 0.35s ease;
}

.dropdown-link:hover::after{
  background:var(--blaze-orange);
  transform:scaleX(0.92);
}

.dropdown-link:hover span{
  color:var(--blaze-orange);
}

/* =========================
   MAIN CONTENT
========================= */

main{
  margin-top:75px;
  min-height:100vh;
  background:#000;
}

.top-line{
  width:100%;
  height:1px;
  background:rgba(249,104,0,0.45);
}

.wrapper{
  padding:90px 70px 110px;
}

.title{
  text-align:center;
  font-size:30px;
  font-weight:800;
  margin-bottom:80px;
}

.grid-3{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:50px;
  text-align:center;
}

.card h3{
  color:var(--blaze-orange);
  font-size:24px;
  margin-bottom:10px;
}

.card p{
  color:#ddd;
  font-size:15px;
}

.space{
  margin-top:120px;
}

.ack{
  margin-top:140px;
}

.ack h2{
  text-align:center;
  font-size:40px;
  margin-bottom:40px;
}

.ack p{
  text-align:center;
  color:#ddd;
  line-height:2;
}

/* =========================
   FOOTER
========================= */

footer{
  background:
  radial-gradient(circle at center,
  var(--dark-purple),
  #000);

  padding:50px 20px;

  border-top:1px solid rgba(255,255,255,0.08);

  text-align:center;
}

.footer-container{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:10px;
}

.footer-container p{
  color:#ededed;
  font-size:11px;
  line-height:1.8;
}

.copyright{
  color:var(--yellow-orange);
  font-weight:600;
  font-size:8.6px;
  font-style:italic;
}

/* =========================
   MOBILE
========================= */

@media(max-width:768px){


  header{
    height:auto;
    padding:14px 16px 18px;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:14px;
  }

  /* LOGO TOP */

  .logo-center{
    order:-1;
    position:static;
    transform:none;

    width:100%;

    display:flex;
    justify-content:center;
    align-items:center;
  }

  .logo-center img{
    width:125px;
  }

  /* TWO ROW NAVIGATION */

  .nav-left,
  .nav-right{
    width:100%;

    display:grid;
    grid-template-columns:1fr 1fr;
    gap:12px;
    
  }

  /* BUTTON STYLE */

  .nav-item,
  .active-btn,
  .about-dropdown-summary,
  .virtual-dropdown-summary{
    width:100%;
    min-height:52px;

    background:rgba(255,255,255,0.06);

    border-radius:12px;

    display:flex;
    align-items:center;
    justify-content:center;

    padding:14px 16px;
  }

  .active-btn{
    height:auto;
    
  }

  .nav-link{
    font-size:13px;
    text-align:center;
  }

  /* DROPDOWN */

  .about-dropdown-wrapper,
  .virtual-dropdown-wrapper{
    width:100%;
  }

  .about-dropdown-summary,
  .virtual-dropdown-summary{
    justify-content:center;
  gap:10px;
  }

  .dropdown-menu{
    position:absolute;

    width:100%;

    margin-top:10px;

    padding:18px 16px;

    border-radius:14px;

    transform:none;
  }

  .dropdown-column{
    flex-direction:column;
    gap:18px;
  }

  .dropdown-link{
    width:100%;
  }

  /* CONTENT */

  main{
    margin-top:240px;
  }

  .wrapper{
    padding:40px 20px 80px;
  }

  .grid-3{
    grid-template-columns:1fr;
  }

  .title{
    font-size:24px;
  }

  .ack h2{
    font-size:30px;
  }

  footer{
    padding:40px 16px;
  }

  footer img{
    width:180px !important;
  }
}
</style>
</head>

